# ============================================================
#  Пример конфигурации. Скопируй этот файл в .env и заполни.
#  (Windows PowerShell:  Copy-Item .env.example .env)
# ============================================================

# --- Telegram ---
# Токен бота от @BotFather (https://t.me/BotFather -> /newbot)
BOT_TOKEN=

# Имя/характер бота (можно поменять, влияет на тон ответов)
BOT_NAME=Нота

# --- Gemini (Google AI Studio) ---
# Бесплатные ключи: https://aistudio.google.com/app/apikey
#
# Можно указать НЕСКОЛЬКО ключей через запятую — бот будет их чередовать
# (round-robin) и автоматически переключаться, когда ключ упрётся в лимит.
# Для 20-50 пользователей рекомендуется 3-5 ключей ИЗ РАЗНЫХ Google-аккаунтов
# (ключи одного проекта делят общую квоту и НЕ суммируют лимиты).
GEMINI_API_KEYS=key_1,key_2,key_3

# (необязательно) старый вариант на один ключ — тоже работает.
# Если задано и GEMINI_API_KEYS, и GEMINI_API_KEY — все ключи объединяются.
GEMINI_API_KEY=

# Модель. gemini-2.0-flash — быстрая и бесплатная. Для PREMIUM можно gemini-2.5-pro.
GEMINI_MODEL=gemini-2.0-flash

# --- Qwen (Alibaba DashScope, OpenAI-совместимый) ---
# Ключ(и) из https://dashscope-intl.console.aliyun.com (Create API key, вид sk-...).
# Можно несколько через запятую — будет ротация при лимите.
QWEN_API_KEYS=sk-...
# Базовый URL международного эндпоинта (как на странице API Keys).
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Модель с поддержкой изображений. qwen-vl-max — сильная; qwen-vl-plus — дешевле.
QWEN_MODEL=qwen-vl-max
# Модель распознавания речи (голосовые). qwen3-asr-flash — быстрая, многоязычная.
QWEN_ASR_MODEL=qwen3-asr-flash

# Какой ИИ-провайдер использовать: gemini | qwen | gigachat
AI_PROVIDER=qwen

# --- (опционально) GigaChat от Сбера ---
# Авторизационные данные (Base64) из личного кабинета GigaChat API.
GIGACHAT_CREDENTIALS=

# --- Общие настройки ---
# Часовой пояс по умолчанию для напоминаний
TIMEZONE=Europe/Moscow
# Путь к файлу базы данных
DATABASE_PATH=data/bot.db
# Лимит заметок на бесплатном тарифе
FREE_NOTES_LIMIT=50

# ID администраторов через запятую (могут менять тарифы и т.п.), например: 12345678,87654321
ADMIN_IDS=
